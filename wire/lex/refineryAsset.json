{
  "lexicon": 1,
  "id": "com.etzhayyim.kamado.refineryAsset",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "refineryId",
          "country",
          "status",
          "isObservation"
        ],
        "properties": {
          "refineryId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "operator": {
            "type": "string",
            "description": "org.corp.* id (kabuto) — an org, NEVER a person (G4)"
          },
          "throughputBpd": {
            "type": "integer",
            "description": ":representative public-bulletin figure"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "idled",
              "decommissioning",
              "converted"
            ]
          },
          "transitionReadiness": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "isObservation": {
            "type": "boolean",
            "const": true,
            "description": "G4 — kamado OBSERVES public assets; observation ≠ operation; not a target-list"
          },
          "sourcing": {
            "type": "string",
            "enum": [
              "representative",
              "synthesized",
              "verified"
            ]
          }
        }
      }
    }
  }
}
