{:lexicon 1
 :id "com.etzhayyim.kamado.feedstockProvenance"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["feedstockClass" "closedLoop" "screened"]
    :properties
    {:feedstockClass {:type "string"
                      :enum ["biogenic" "captured-co2" "recycled-carbon" "existing-inventory-decommission"]
                      :description "G1 — closed-loop carbon ONLY; `fossil-virgin-crude` is NOT an enum member (excluded by construction; robotics cannot neutralize fossil carbon)"}
     :closedLoop  {:type "boolean" :const true
                   :description "G1 — a provenance record exists ONLY for closed-loop carbon"}
     :screened    {:type "boolean" :const true
                   :description "G1 — record only exists after the feedstock-class screen passes (ValueError on fossil)"}
     :sourcing    {:type "string" :enum ["representative" "synthesized" "verified"]}}}}}}
