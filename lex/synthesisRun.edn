{:lexicon 1
 :id "com.etzhayyim.kamado.synthesisRun"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["synthesisId" "feedstockClass" "energy" "productFate"]
    :properties
    {:synthesisId {:type "string"}
     :feedstockClass {:type "string"
                      :enum ["biogenic" "captured-co2" "recycled-carbon" "existing-inventory-decommission"]
                      :description "G1 — MUST be a closed-loop carbon class (no fossil member)"}
     :energy      {:type "string" :enum ["hikari-renewable" "grid-mixed"]
                   :description "G2 — hikari-renewable required to pass D3"}
     :productFate {:type "string" :enum ["combusted-fuel" "durable-material"]
                   :description "G12 — durable-material requires an end-of-life route (hodoki/kanayama)"}
     :control     {:type "string" :enum ["teleop" "supervised-autonomy"]
                   :description "tazuna sibling; G5 no-server-key; Transparent Force §1.12.B"}
     :sourcing    {:type "string" :enum ["representative" "synthesized" "verified"]}}}}}}
