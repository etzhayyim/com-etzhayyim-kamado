{:lexicon 1
 :id "com.etzhayyim.kamado.carbonBalance"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["synthesisId" "netDeltaTco2ePerT" "passesD3"]
    :properties
    {:synthesisId {:type "string" :description "→ synthesisRun.synthesisId"}
     :netDeltaTco2ePerT {:type "number" :description "G2/D3 — net atmospheric carbon Δ; MUST be ≤ tolerance"}
